<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS Publish Profile — framework-dependent deployment to C:\inetpub\wwwroot\ota-api
  Run: dotnet publish OTA.API.csproj /p:PublishProfile=IIS-Production -c Release
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <PublishProvider>FileSystem</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <!-- Output folder — IIS site physical path -->
    <PublishUrl>C:\inetpub\wwwroot\ota-api</PublishUrl>
    <DeleteExistingFiles>True</DeleteExistingFiles>
    <ExcludeApp_Data>True</ExcludeApp_Data>
    <TargetFramework>net8.0</TargetFramework>
    <!-- Framework-dependent: relies on .NET 8 Hosting Bundle installed on the server -->
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <!-- Generates web.config automatically -->
    <IsWebConfigTransformDisabled>false</IsWebConfigTransformDisabled>
  </PropertyGroup>
</Project>
