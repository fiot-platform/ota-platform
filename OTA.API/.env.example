# MongoDB — replica set connection
MONGODB_CONNECTION_STRING=mongodb://iot.ssmsportal.com:39999/?replicaSet=fiot-rs
MONGODB_DATABASE=OTAPlatform

# JWT
JWT_SECRET=REPLACE_WITH_STRONG_256BIT_RANDOM_SECRET
JWT_ISSUER=OTA.API
JWT_AUDIENCE=OTA.Clients
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Gitea
GITEA_BASE_URL=https://gitea.example.com
GITEA_ADMIN_TOKEN=REPLACE_WITH_GITEA_ADMIN_TOKEN
GITEA_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_HMAC_SECRET
GITEA_TIMEOUT_SECONDS=30

# CORS
CORS_ORIGIN=http://localhost:3000

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
