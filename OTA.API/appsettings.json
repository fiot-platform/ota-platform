{
  "MongoDbSettings": {
    "ConnectionString": "mongodb://iot.ssmsportal.com:39999/?replicaSet=fiot-rs",
    "DatabaseName": "OTAPlatform"
  },
  "JwtSettings": {
    "Secret": "CHANGE_ME_TO_A_STRONG_256BIT_SECRET_KEY_FOR_PRODUCTION_USE",
    "Issuer": "OTA.API",
    "Audience": "OTA.Clients",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "GiteaSettings": {
    "BaseUrl": "http://localhost:3021",
    "AdminToken": "1f577d87d261aa18392c244a7b05843025a7e839",
    "WebhookSecret": "CHANGE_ME_GITEA_WEBHOOK_SECRET",
    "TimeoutSeconds": 30
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:3000", "https://ota-frontend.example.com" ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/ota-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
