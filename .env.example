# ============================================================
# OTA Platform API – Environment Variable Template
# Copy this file to .env and fill in the values before running
# in Docker or docker-compose.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_CONNECTION_STRING=mongodb://ota_user:changeme@mongo:27017/ota_platform?authSource=ota_platform
MONGODB_DATABASE_NAME=ota_platform

# ── JWT ──────────────────────────────────────────────────────
# Must be at least 32 characters (256-bit key for HS256).
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ISSUER=OTAPlatform
JWT_AUDIENCE=OTAPlatformClients
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ── Gitea ─────────────────────────────────────────────────────
GITEA_BASE_URL=https://gitea.example.com
GITEA_ADMIN_TOKEN=your-gitea-api-admin-token
# HMAC-SHA256 secret configured in the Gitea repository webhook settings.
GITEA_WEBHOOK_SECRET=your-gitea-webhook-shared-secret
GITEA_TIMEOUT_SECONDS=30

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://ota.example.com

# ── ASP.NET Core ──────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# ── Serilog ───────────────────────────────────────────────────
# Override the minimum log level (Verbose|Debug|Information|Warning|Error|Fatal).
SERILOG_MIN_LEVEL=Information
