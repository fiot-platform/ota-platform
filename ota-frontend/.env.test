# ─── OTA Platform — Playwright Test Environment ───────────────────────────────
# Template file. Copy to .env.test.local and fill in real credentials.
# .env.test.local is gitignored and contains real secrets.

# Base URL of the running OTA frontend
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Backend API Base URL (used by firmware-approval-workflow tests to call API directly)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
API_BASE_URL=http://localhost:5000/api

# ─── Test User Credentials ────────────────────────────────────────────────────
# These accounts must exist in the platform before running tests.
# Replace placeholders below in your local .env.test.local — never commit real passwords.

SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=replace-me

PLATFORM_ADMIN_EMAIL=platformadmin@example.com
PLATFORM_ADMIN_PASSWORD=replace-me

RELEASE_MANAGER_EMAIL=release@example.com
RELEASE_MANAGER_PASSWORD=replace-me

QA_EMAIL=qa@example.com
QA_PASSWORD=replace-me

VIEWER_EMAIL=viewer@example.com
VIEWER_PASSWORD=replace-me
